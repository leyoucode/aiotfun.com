---
import OptimizedImage from './OptimizedImage.astro';
import { getLocaleFromUrl, useTranslations, localePath } from '../utils/i18n';
import type { Article } from '../types/article';

interface Props {
  article: Article;
  variant?: 'large' | 'medium' | 'small' | 'list';
}

const { article, variant = 'medium' } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const href = localePath(`/writing/${article.slug}/`, locale);

const isList = variant === 'list';
const isSmall = variant === 'small';
const isLarge = variant === 'large';
---

{isList ? (
  <a href={href} class="group flex items-baseline justify-between gap-4 border-b border-border py-4 transition-colors hover:border-accent">
    <div class="min-w-0 flex-1">
      <h3 class="truncate font-body text-base font-bold text-text group-hover:text-accent transition-colors" title={article.title}>
        {article.title}
      </h3>
      <p class="mt-1 truncate text-sm text-text-muted" title={article.description}>{article.description}</p>
    </div>
    <span class="shrink-0 font-mono text-xs text-text-muted">{article.date}</span>
  </a>
) : (
  <a href={href} class="group block overflow-hidden rounded-card border border-border bg-card-bg shadow-card transition-shadow hover:shadow-md">
    {article.cover && (
      <div class:list={['overflow-hidden', isSmall ? 'h-28' : isLarge ? 'h-56' : 'h-44']}>
        <OptimizedImage
          src={article.cover}
          alt={article.title}
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
          widths={[300, 400, 600]}
          sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 400px"
          loading="lazy"
        />
      </div>
    )}
    <div class:list={[isSmall ? 'p-3' : 'p-4']}>
      <h3 class:list={[
        'font-body font-bold leading-snug text-text group-hover:text-accent transition-colors line-clamp-2',
        isSmall ? 'text-sm' : isLarge ? 'text-lg' : 'text-base',
      ]} title={article.title}>
        {article.title}
      </h3>
      {!isSmall && (
        <p class="mt-2 text-sm text-text-muted line-clamp-2" title={article.description}>
          {article.description}
        </p>
      )}
      <div class="mt-3 flex items-center gap-2 font-mono text-xs text-text-muted">
        <span>{article.date}</span>
        <span>·</span>
        <span>{article.readingTime} {t.article.min_read}</span>
        {article.tags.length > 0 && (
          <>
            <span>·</span>
            <span class="truncate">#{article.tags[0]}</span>
          </>
        )}
      </div>
    </div>
  </a>
)}
