---
import { getLocaleFromUrl, useTranslations, localePath } from '../utils/i18n';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const year = new Date().getFullYear();
const rssHref = locale === 'zh' ? '/zh/rss.xml' : '/rss.xml';
---

<footer class="border-t border-border bg-bg py-8">
  <div class="mx-auto flex max-w-content flex-col items-center justify-between gap-4 px-4 sm:flex-row md:px-6">
    <a href={localePath('/', locale)} class="font-body text-lg font-bold tracking-tight">
      <span class="text-text">AIoT</span><span class="text-accent">Fun</span>
    </a>

    <div class="flex flex-wrap justify-center items-center gap-4 font-body text-xs text-text-muted">
      <a href="https://github.com/leyoucode" target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-accent">GitHub</a>
      <span class="text-border">·</span>
      <a href="https://x.com/notifywei" target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-accent">X</a>
      <span class="text-border">·</span>
      <a href="mailto:notifywei@gmail.com" class="transition-colors hover:text-accent">Email</a>
      <span class="text-border">·</span>
      <a href={rssHref} class="transition-colors hover:text-accent">RSS</a>
    </div>

    <p class="font-body text-xs text-text-muted">{t.footer.copyright.replace('{year}', String(year))}</p>
  </div>
</footer>
