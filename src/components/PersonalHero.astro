---
import { getLocaleFromUrl, useTranslations, localePath } from '../utils/i18n';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<section class="mx-auto max-w-content px-4 pt-12 pb-8 md:px-6 md:pt-20 md:pb-12">
  <div class="flex flex-col items-start gap-3 max-w-prose">
    <span class="font-mono text-xs uppercase tracking-wider text-text-muted">{t.home.hero_role}</span>
    <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.1] text-text">
      <span class="text-text">AIoT</span><span class="text-accent">Fun</span>
      <span class="block mt-1 text-text-muted text-2xl md:text-3xl lg:text-4xl font-display">{t.site.tagline}</span>
    </h1>
    <p class="mt-4 text-lg leading-relaxed text-text/80">
      {t.home.hero_summary}
    </p>
    <div class="mt-3 flex flex-wrap gap-3 font-mono text-sm">
      <a href="https://github.com/leyoucode" target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-1.5 rounded-full border border-border bg-card-bg px-4 py-1.5 text-text-muted hover:border-accent hover:text-accent transition-colors">
        GitHub
      </a>
      <a href="https://x.com/notifywei" target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-1.5 rounded-full border border-border bg-card-bg px-4 py-1.5 text-text-muted hover:border-accent hover:text-accent transition-colors">
        X
      </a>
      <a href="mailto:notifywei@gmail.com"
         class="inline-flex items-center gap-1.5 rounded-full border border-border bg-card-bg px-4 py-1.5 text-text-muted hover:border-accent hover:text-accent transition-colors">
        Email
      </a>
      <a href={localePath('/now/', locale)}
         class="inline-flex items-center gap-1.5 rounded-full border border-accent bg-accent/10 px-4 py-1.5 text-accent hover:bg-accent hover:text-white transition-colors">
        Now →
      </a>
    </div>
  </div>
</section>
