---
import OptimizedImage from './OptimizedImage.astro';
import { t, getStatusColor } from '../utils/i18n';
import type { Project } from '../types/article';

interface Props {
  project: Project;
  variant?: 'featured' | 'medium';
}

const { project, variant = 'medium' } = Astro.props;
const href = `/projects/${project.slug}/`;

const statusLabel = (t as any).project_status[project.status] ?? project.status;
const statusColor = getStatusColor(project.status);
const isFeatured = variant === 'featured';
---

<a href={href} class="group block overflow-hidden rounded-card border border-border bg-card-bg shadow-card transition-shadow hover:shadow-md">
  {project.cover && (
    <div class:list={['overflow-hidden', isFeatured ? 'h-44' : 'h-36']}>
      <OptimizedImage
        src={project.cover}
        alt={project.title}
        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
        widths={[300, 400, 600]}
        sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 400px"
        loading="lazy"
      />
    </div>
  )}
  <div class="p-4">
    <div class="mb-2 flex items-center gap-2">
      <span class="inline-flex items-center gap-1.5 font-mono text-[11px] uppercase tracking-wide text-text-muted">
        <span class="inline-block h-2 w-2 rounded-full" style={`background:${statusColor}`}></span>
        {statusLabel}
      </span>
    </div>
    <h3 class="font-body text-lg font-bold leading-snug text-text group-hover:text-accent transition-colors line-clamp-2" title={project.title}>
      {project.title}
    </h3>
    <p class="mt-1.5 text-sm text-text-muted line-clamp-2" title={project.oneLiner}>
      {project.oneLiner}
    </p>
    {project.techStack.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5">
        {project.techStack.slice(0, 4).map((tech) => (
          <span class="rounded-full border border-border bg-bg px-2 py-0.5 font-mono text-[10px] text-text-muted">{tech}</span>
        ))}
      </div>
    )}
  </div>
</a>
