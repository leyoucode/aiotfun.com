---
import ArticleCard from './ArticleCard.astro';
import { getLocaleFromUrl, useTranslations, localePath } from '../utils/i18n';
import { getLatestArticles } from '../utils/articles';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const recent = await getLatestArticles(locale, 5);
---

<section class="mx-auto max-w-content px-4 py-8 md:px-6 md:py-12">
  <div class="mb-4 flex items-baseline justify-between">
    <h2 class="font-display text-2xl md:text-3xl font-bold text-text">{t.home.recent_writing}</h2>
    <a href={localePath('/writing/', locale)} class="font-body text-sm text-text-muted hover:text-accent transition-colors">
      {t.home.all_writing}
    </a>
  </div>

  {recent.length > 0 ? (
    <div>
      {recent.map((a) => <ArticleCard article={a} variant="list" />)}
    </div>
  ) : (
    <p class="text-text-muted">{t.home.no_writing}</p>
  )}
</section>
