---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../utils/i18n';

const about = (t as any).about;

const stack = [
  { group: '编程语言', items: ['TypeScript', 'Python', 'Go', 'C', 'MicroPython'] },
  { group: '前端', items: ['Astro', 'React', 'Tailwind', 'Vite'] },
  { group: 'AI / LLM', items: ['Anthropic API', 'OpenAI API', 'Ollama', '函数调用 Agent'] },
  { group: '硬件', items: ['ESP32', 'ESP32-S3', 'Raspberry Pi', 'BLE / Wi-Fi / LoRa'] },
  { group: '后端 / 基础设施', items: ['Cloudflare Workers', 'SQLite', 'PostgreSQL', 'Docker', '阿里云'] },
];
---

<BaseLayout title={`${about.title} — ${t.site.name}`} description={t.site.description}>
  <div class="mx-auto max-w-content px-4 md:px-6 py-12 md:py-16">

    <div class="max-w-prose">
      <span class="font-mono text-xs uppercase tracking-wider text-text-muted">{about.title}</span>
      <h1 class="mt-2 font-display text-3xl md:text-5xl font-bold text-text leading-tight">{about.intro_title}</h1>
      <div class="mt-6 space-y-4 text-text/90 leading-relaxed text-lg">
        <p>{about.intro_p1}</p>
        <p>{about.intro_p2}</p>
        <p>{about.intro_p3}</p>
      </div>
    </div>

    <section class="mt-16 max-w-prose">
      <h2 class="font-display text-2xl font-bold text-text mb-6">{about.stack_title}</h2>
      <dl class="space-y-4">
        {stack.map((row) => (
          <div class="flex flex-col gap-2 sm:flex-row sm:items-baseline sm:gap-6">
            <dt class="shrink-0 font-mono text-xs uppercase tracking-wider text-text-muted sm:w-32">{row.group}</dt>
            <dd class="flex flex-wrap gap-2">
              {row.items.map((item) => (
                <span class="rounded-full border border-border bg-card-bg px-3 py-1 font-mono text-xs text-text-muted">{item}</span>
              ))}
            </dd>
          </div>
        ))}
      </dl>
    </section>

    <section class="mt-16 max-w-prose">
      <h2 class="font-display text-2xl font-bold text-text mb-3">{about.now_title}</h2>
      <p class="text-text/90 leading-relaxed">
        实时更新见 <a href="/now/" class="text-accent hover:underline">近况页</a>。
      </p>
    </section>

    <section class="mt-16 max-w-prose">
      <h2 class="font-display text-2xl font-bold text-text mb-3">{about.contact_title}</h2>
      <p class="text-text/90 leading-relaxed mb-4">{about.contact_desc}</p>
      <div class="flex flex-wrap gap-3 font-mono text-sm">
        <a href="https://github.com/leyoucode" target="_blank" rel="noopener noreferrer" class="rounded-full border border-border bg-card-bg px-4 py-1.5 text-text-muted hover:border-accent hover:text-accent transition-colors">GitHub</a>
        <a href="https://x.com/AIoTFun" target="_blank" rel="noopener noreferrer" class="rounded-full border border-border bg-card-bg px-4 py-1.5 text-text-muted hover:border-accent hover:text-accent transition-colors">X</a>
      </div>
    </section>

  </div>
</BaseLayout>
