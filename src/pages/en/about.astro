---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, localePath } from '../../utils/i18n';

const locale = 'en';
const t = useTranslations(locale);
const about = (t as any).about;

const stack = [
  { group: 'Languages', items: ['TypeScript', 'Python', 'Go', 'C', 'MicroPython'] },
  { group: 'Frontend', items: ['Astro', 'React', 'Tailwind', 'Vite'] },
  { group: 'AI / LLM', items: ['Anthropic API', 'OpenAI API', 'Ollama', 'function-calling agents'] },
  { group: 'Hardware', items: ['ESP32', 'ESP32-S3', 'Raspberry Pi', 'BLE / Wi-Fi / LoRa'] },
  { group: 'Backend / Infra', items: ['Cloudflare Workers', 'SQLite', 'PostgreSQL', 'Docker', 'Aliyun'] },
];

const projectTimeline = [
  { year: '2026', items: ['AIoTFun.com — this site', 'AI Smart Alarm — ESP32-based voice alarm clock'] },
  { year: '2025', items: ['GEO platform — search/sentiment intelligence', 'MASF AI — voice / translation / image platform'] },
  { year: '2024 and earlier', items: ['Cloud Print POS', 'JSD Logistics', 'Meituan gateway', '3D-print modelling toolkit', 'Action camera firmware'] },
];
---

<BaseLayout title={`${about.title} — ${t.site.name}`} description={t.site.description}>
  <div class="mx-auto max-w-content px-4 md:px-6 py-12 md:py-16">

    <div class="max-w-prose">
      <span class="font-mono text-xs uppercase tracking-wider text-text-muted">{about.title}</span>
      <h1 class="mt-2 font-display text-3xl md:text-5xl font-bold text-text leading-tight">{about.intro_title}</h1>
      <div class="mt-6 space-y-4 text-text/90 leading-relaxed text-lg">
        <p>{about.intro_p1}</p>
        <p>{about.intro_p2}</p>
        <p>{about.intro_p3}</p>
      </div>
    </div>

    <section class="mt-16 max-w-prose">
      <h2 class="font-display text-2xl font-bold text-text mb-6">{about.stack_title}</h2>
      <dl class="space-y-4">
        {stack.map((row) => (
          <div class="flex flex-col gap-2 sm:flex-row sm:items-baseline sm:gap-6">
            <dt class="shrink-0 font-mono text-xs uppercase tracking-wider text-text-muted sm:w-32">{row.group}</dt>
            <dd class="flex flex-wrap gap-2">
              {row.items.map((item) => (
                <span class="rounded-full border border-border bg-card-bg px-3 py-1 font-mono text-xs text-text-muted">{item}</span>
              ))}
            </dd>
          </div>
        ))}
      </dl>
    </section>

    <section class="mt-16 max-w-prose">
      <h2 class="font-display text-2xl font-bold text-text mb-6">Projects timeline</h2>
      <ol class="space-y-6 border-l border-border pl-6">
        {projectTimeline.map((row) => (
          <li>
            <div class="font-mono text-xs uppercase tracking-wider text-text-muted">{row.year}</div>
            <ul class="mt-1 space-y-1">
              {row.items.map((item) => <li class="text-text/90">{item}</li>)}
            </ul>
          </li>
        ))}
      </ol>
      <a href={localePath('/projects/', locale)} class="mt-6 inline-block font-body text-sm text-accent hover:underline">
        See all projects →
      </a>
    </section>

    <section class="mt-16 max-w-prose">
      <h2 class="font-display text-2xl font-bold text-text mb-3">{about.now_title}</h2>
      <p class="text-text/90 leading-relaxed">
        Living updates on the <a href={localePath('/now/', locale)} class="text-accent hover:underline">Now page</a>.
      </p>
    </section>

    <section class="mt-16 max-w-prose">
      <h2 class="font-display text-2xl font-bold text-text mb-3">{about.contact_title}</h2>
      <p class="text-text/90 leading-relaxed mb-4">{about.contact_desc}</p>
      <div class="flex flex-wrap gap-3 font-mono text-sm">
        <a href="mailto:notifywei@gmail.com" class="rounded-full border border-border bg-card-bg px-4 py-1.5 text-text-muted hover:border-accent hover:text-accent transition-colors">Email</a>
        <a href="https://github.com/leyoucode" target="_blank" rel="noopener noreferrer" class="rounded-full border border-border bg-card-bg px-4 py-1.5 text-text-muted hover:border-accent hover:text-accent transition-colors">GitHub</a>
        <a href="https://x.com/notifywei" target="_blank" rel="noopener noreferrer" class="rounded-full border border-border bg-card-bg px-4 py-1.5 text-text-muted hover:border-accent hover:text-accent transition-colors">X</a>
      </div>
    </section>

  </div>
</BaseLayout>
