---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../utils/i18n';

const now = (t as any).now;
const lastUpdated = '2026-04-29';
---

<BaseLayout title={`${now.title} — ${t.site.name}`} description={now.subtitle}>
  <div class="mx-auto max-w-content px-4 md:px-6 py-12 md:py-16">
    <div class="max-w-prose">
      <span class="font-mono text-xs uppercase tracking-wider text-text-muted">{now.title}</span>
      <h1 class="mt-2 font-display text-3xl md:text-5xl font-bold text-text leading-tight">{now.subtitle}</h1>
      <p class="mt-3 font-mono text-xs text-text-muted">最近更新：{lastUpdated}</p>

      <div class="mt-10 article-body">
        <p>这页还没填好。整理一下再放上来。</p>
      </div>

      <p class="mt-10 font-mono text-xs text-text-muted">{now.footer_note}</p>
    </div>
  </div>
</BaseLayout>
