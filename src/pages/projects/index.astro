---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { t } from '../../utils/i18n';
import { getProjects } from '../../utils/projects';

const projects = await getProjects();
---

<BaseLayout title={`${(t as any).projects.title} — ${t.site.name}`} description={(t as any).projects.subtitle}>
  <div class="mx-auto max-w-content px-4 md:px-6 py-12 md:py-16">
    <div class="max-w-prose mb-10">
      <h1 class="font-display text-3xl md:text-5xl font-bold text-text">{(t as any).projects.title}</h1>
      <p class="mt-4 text-lg text-text-muted">{(t as any).projects.subtitle}</p>
    </div>

    {projects.length > 0 ? (
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {projects.map((p) => <ProjectCard project={p} variant="featured" />)}
      </div>
    ) : (
      <p class="text-text-muted">{(t as any).projects.no_projects}</p>
    )}
  </div>
</BaseLayout>
