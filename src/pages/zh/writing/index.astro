---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { useTranslations } from '../../../utils/i18n';
import { getArticles } from '../../../utils/articles';

const locale = 'zh';
const t = useTranslations(locale);
const articles = await getArticles(locale);
---

<BaseLayout title={`${(t as any).writing.title} — ${t.site.name}`} description={(t as any).writing.subtitle}>
  <div class="mx-auto max-w-content px-4 md:px-6 py-12 md:py-16">
    <div class="max-w-prose mb-10">
      <h1 class="font-display text-3xl md:text-5xl font-bold text-text">{(t as any).writing.title}</h1>
      <p class="mt-4 text-lg text-text-muted">{(t as any).writing.subtitle}</p>
    </div>

    {articles.length > 0 ? (
      <div class="max-w-prose">
        {articles.map((a) => <ArticleCard article={a} variant="list" />)}
      </div>
    ) : (
      <p class="text-text-muted">{(t as any).writing.no_writing}</p>
    )}
  </div>
</BaseLayout>
